# ═══════════════════════════════════════════════════════════════════════
# WEGO BACKEND — ENV TEMPLATE  (committed; NO real secrets here)
# ═══════════════════════════════════════════════════════════════════════
# Copy to .env.development (localhost) or .env.production (server) and fill in.
#   cp .env.example .env.development && cp .env.development .env
# ═══════════════════════════════════════════════════════════════════════

# ─── Application ───────────────────────────────────────────────────────
NODE_ENV=development            # development | production
PORT=10002
APP_NAME=WEGO
TZ=Africa/Douala

# ─── Database (MySQL) ──────────────────────────────────────────────────
DB_NAME=WEGO
DB_USER=wego
DB_PASS=
DB_HOST=127.0.0.1               # docker: host.docker.internal
DB_PORT=3306

# ─── SMS (Techsoft) ────────────────────────────────────────────────────
TECHSOFT_API_TOKEN=
TECHSOFT_SENDER_ID=PROXYM
TECHSOFT_SMS_URL=https://app.techsoft-sms.com/api/http/sms/send/
TECHSOFT_SMS_TIMEOUT=15000

# ─── Redis ─────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379   # docker: redis://redis:6379
GEO_KEY=drivers:geo
META_KEY_PREFIX=driver:meta:
TRIP_OFFERS_PREFIX=trip:offers:
OFFER_TTL_MS=2000000
LOCK_TTL_MS=100000

# ─── JWT — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── Password / OTP ────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
OTP_TTL_MIN=10
OTP_LEN=6

# ─── Twilio ────────────────────────────────────────────────────────────
TWILIO_SID=
TWILIO_TOKEN=
SMS_FROM=

# ─── SendGrid ──────────────────────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM=

# ─── SMTP ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
MAIL_FROM_NAME=WEGO

# ─── Cloudflare R2 ─────────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
R2_REGION=auto
USE_R2_STORAGE=false            # true in production (shared uploads)

# ─── Mapbox ────────────────────────────────────────────────────────────
MAPBOX_ACCESS_TOKEN=
DEFAULT_CITY=Douala

# ─── Mobile Money ──────────────────────────────────────────────────────
ORANGE_MONEY_API_URL=https://api.orange.com/orange-money-webpay/cm/v1
ORANGE_MONEY_MERCHANT_KEY=
ORANGE_MONEY_MERCHANT_SECRET=
MTN_MOMO_API_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_SUBSCRIPTION_KEY=
MTN_MOMO_API_USER=
MTN_MOMO_API_KEY=
MTN_MOMO_CALLBACK_URL=http://localhost:10002/api/payments/mtn/callback

# ─── Socket.io & CORS (comma-separated allowlist; never * in prod) ─────
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true
SOCKET_CORS_ORIGIN=http://localhost:3000
SOCKET_PING_TIMEOUT=60000
SOCKET_PING_INTERVAL=25000

# ─── Rate limiting ─────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10

# ─── Frontend URLs ─────────────────────────────────────────────────────
BACKOFFICE_URL=http://localhost:3000
WEB_APP_URL=http://localhost:3001
MOBILE_APP_SCHEME=wego://

# ─── Business config ───────────────────────────────────────────────────
COMMISSION_RATE=0.15
DEFAULT_CURRENCY=XAF
PLATFORM_FEE_PERCENTAGE=15
SERVICE_COMMISSION_RATE=0.15

# ─── Security ──────────────────────────────────────────────────────────
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_DURATION_MINUTES=30

# ─── File upload limits (bytes) ────────────────────────────────────────
MAX_PROFILE_IMAGE_SIZE=5242880
MAX_DOCUMENT_SIZE=10485760
MAX_VEHICLE_IMAGE_SIZE=5242880

# ─── Logging ───────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=logs/wego.log

# ─── Ride config ───────────────────────────────────────────────────────
SEARCH_RADIUS_KM=10
MAX_DRIVERS_TO_NOTIFY=10
DRIVER_RESPONSE_TIMEOUT_SECONDS=30
TRIP_SEARCH_EXPIRY_SECONDS=300

# ─── Services marketplace ──────────────────────────────────────────────
AUTO_CONFIRM_PAYMENT_HOURS=48
MAX_SERVICE_IMAGES=5
SERVICE_LISTING_APPROVAL_REQUIRED=true

# ─── Vehicle rental ────────────────────────────────────────────────────
RENTAL_COMMISSION_RATE=0.15
MIN_RENTAL_HOURS=3
MAX_RENTAL_DAYS=30

# ─── Google OAuth ──────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=

# ─── CamPay ────────────────────────────────────────────────────────────
CAMPAY_APP_USERNAME=
CAMPAY_APP_PASSWORD=
CAMPAY_BASE_URL=https://demo.campay.net/api    # prod: https://www.campay.net/api
CAMPAY_WEBHOOK_SECRET=
CAMPAY_PERMANENT_TOKEN=
CAMPAY_ENV=DEV                  # DEV | PROD

# ─── Firebase (path to service account JSON, mounted at runtime) ───────
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# ─── Background jobs (true only on ONE instance) ───────────────────────
RUN_JOBS=true

# ─── Sentry (error monitoring / tracing / logs / profiling) ───────────────────
# Get the DSN from your Sentry project settings. instrument.js falls back to the
# project DSN if this is unset. All the SENTRY_* vars below are optional.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=1.0
# SENTRY_ENABLED=false        # disable the SDK entirely
# SENTRY_SEND_PII=true        # attach IP / request bodies / user data
# SENTRY_DEBUG_ROUTE=true     # exposes GET /debug-sentry to verify wiring
